			<string>398244BA-9D62-5B55-8808-C7101FE240A9</string>
			<key>PayloadDisplayName</key>
			<string>Firezone</string>
			<key>PayloadOrganization</key>
			<string>com.acme</string>
		</dict>
	</array>
	<key>PayloadOrganization</key>
	<string>com.acme</string>
	<key>PayloadUUID</key>
	<string>CDC021E3-74CB-5972-8604-C878C852AE28</string>
	<key>PayloadDisplayName</key>
	<string>Firezone</string>
