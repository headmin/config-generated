			<key>hideResourceList</key>
			<false/>
			<key>connectOnStart</key>
			<false/>
			<key>startOnLogin</key>
			<false/>
			<key>disableUpdateCheck</key>
			<false/>
			<key>supportURL</key>
			<string>&quot;https://www.firezone.dev/support&quot;</string>
			<key>PayloadType</key>
			<string>dev.firezone.firezone</string>
