			<false/>
			<key>CacheLimit</key>
			<integer>0</integer>
			<key>DataPath</key>
			<string>&quot;/Library/Application Support/Apple/AssetCache/Data&quot;</string>
			<key>DenyTetheredCaching</key>
			<false/>
			<key>DisplayAlerts</key>
			<false/>
			<key>KeepAwake</key>
			<false/>
			<key>ListenRanges</key>
			<array/>
			<key>ListenRangesOnly</key>
			<false/>
			<key>ListenWithPeersAndParents</key>
			<true/>
			<key>LocalSubnetsOnly</key>
			<true/>
			<key>LogClientIdentity</key>
			<false/>
