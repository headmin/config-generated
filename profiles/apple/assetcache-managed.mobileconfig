			<integer>0</integer>
			<key>PublicRanges</key>
			<array/>
			<key>PersonalCacheLimit</key>
			<integer>0</integer>
			<key>AgeForLowSpaceAlert</key>
			<integer>30</integer>
			<key>AllowImports</key>
			<true/>
			<key>AllowWirelessPortable</key>
			<true/>
			<key>DatabaseUpdateInterval</key>
			<integer>5</integer>
			<key>DownloadMinRate</key>
			<integer>8000</integer>
